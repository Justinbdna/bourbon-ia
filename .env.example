# Bourbon.IA — variables d'environnement
# Copiez ce fichier en `.env` (non versionné) et adaptez les valeurs.

# URL du serveur LLM local compatible OpenAI (LM Studio ou Ollama).
# - Mac local     : http://127.0.0.1:1234/v1
# - PC distant LAN : http://<ip-tailscale>:1234/v1
LLM_API_URL=http://127.0.0.1:1234/v1
